# --- DATABASE ---
# Used for Docker Compose and local DB setup
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=payload_db

# Database connection string
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@127.0.0.1:5432/${POSTGRES_DB}

# --- SECRETS ---
# Generate a random 32+ char string for these
PAYLOAD_SECRET=YOUR_RANDOM_LONG_SECRET
CRON_SECRET=YOUR_CRON_SECRET
PREVIEW_SECRET=YOUR_PREVIEW_SECRET

# --- URLS ---
# No trailing slash. Use https in production
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- SEED & ADMIN ---
# WARNING: PAYLOAD_SEED should be 'false' in production to avoid data overwrites
PAYLOAD_SEED=true
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin